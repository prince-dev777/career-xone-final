{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/admission(.*)", "destination": "/server.js" },
    { "source": "/contacts(.*)", "destination": "/server.js" },
    { "source": "/testseries(.*)", "destination": "/server.js" },
    { "source": "/scholarships(.*)", "destination": "/server.js" }
  ]
}