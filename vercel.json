{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/(admin-login|admin|register|user-login|contact|contacts|admission|admissions|testseries|scholarship|scholarships|users)(.*)", "destination": "/server.js" }
  ]
}